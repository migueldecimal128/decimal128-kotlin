fun calcDigitCount64(dw0: Long) : Int {
    var lo = 0
    var hi = POW10_64xor.size
    val dw0x = dw0 xor (1L shl 63)
    do {
        val mid = (lo + hi) / 2
        val m0x = POW10_64xor[mid]
        if (dw0x > m0x)
            lo = mid + 1
        else
            hi = mid
    } while (lo < hi)
    val digitCount = POW10_64_INDEX_OFFSET + lo
    return digitCount
}

fun calcDigitCount64(dw0: ULong) = calcDigitCount64(dw0.toLong())

fun calcDigitCount128(dw1: Long, dw0: Long) : Int {
    var lo = 0
    var hi = POW10_128xor.size/2
    val dw1x = dw1 xor (1L shl 63)
    do {
        val mid = (lo + hi) / 2
        val m1x = POW10_128xor[mid*2]
        if (dw1x > m1x) {
            lo = mid + 1
        } else if (dw1x != m1x) {
            hi = mid
        } else {
            val dw0x = dw0 xor (1L shl 63)
            val m0x = POW10_128xor[mid*2 + 1]
            if (dw0x > m0x)
                lo = mid + 1
            else
                hi = mid
        }
    } while (lo < hi)
    val digitCount = POW10_128_INDEX_OFFSET + lo
    return digitCount
}

fun calcDigitCount192(dw2: Long, dw1: Long, dw0: Long) : Int {
    var lo = 0
    var hi = POW10_192xor.size/3
    val dw2x = dw2 xor (1L shl 63)
    do {
        val mid = (lo + hi) / 2
        val m2x = POW10_192xor[mid * 3]
        if (dw2x > m2x) {
            lo = mid + 1
        } else if (dw2x != m2x) {
            hi = mid
        } else {
            val dw1x = dw1 xor (1L shl 63)
            val m1x = POW10_192xor[mid * 3 + 1]
            if (dw1x > m1x) {
                lo = mid + 1
            } else if (dw1x != m1x) {
                hi = mid
            } else {
                val dw0x = dw0 xor (1L shl 63)
                val m0x = POW10_192xor[mid * 3 + 2]
                if (dw0x > m0x)
                    lo = mid + 1
                else
                    hi = mid
            }
        }
    } while (lo < hi)
    val digitCount = POW10_192_INDEX_OFFSET + lo
    return digitCount
}

fun calcDigitCount256(dw3: Long, dw2: Long, dw1: Long, dw0: Long) : Int {
    var lo = 0
    var hi = POW10_256xor.size/4
    val dw3x = dw3 xor (1L shl 63)
    do {
        val mid = (lo + hi) / 2
        val m3x = POW10_256xor[mid * 4]
        if (dw3x > m3x) {
            lo = mid + 1
        } else if (dw3x != m3x) {
            hi = mid
        } else {
            val dw2x = dw2 xor (1L shl 63)
            val m2x = POW10_256xor[mid * 4 + 1]
            if (dw2x > m2x) {
                lo = mid + 1
            } else if (dw2x != m2x) {
                hi = mid
            } else {
                val dw1x = dw1 xor (1L shl 63)
                val m1x = POW10_256xor[mid * 4 + 2]
                if (dw1x > m1x) {
                    lo = mid + 1
                } else if (dw1x != m1x) {
                    hi = mid
                } else {
                    val dw0x = dw0 xor (1L shl 63)
                    val m0x = POW10_256xor[mid * 4 + 3]
                    if (dw0x > m0x)
                        lo = mid + 1
                    else
                        hi = mid
                }
            }
        }
    } while (lo < hi)
    val digitCount = POW10_256_INDEX_OFFSET + lo
    return digitCount
}

fun calcDigitCount(dw1: Long, dw0: Long) : Int {
    return if (dw1 == 0L) calcDigitCount64(dw0) else calcDigitCount128(dw1, dw0)
}

fun calcDigitCount(dw3: Long, dw2: Long, dw1: Long, dw0: Long) : Int {
    if ((dw3 or dw2) == 0L)
        return if (dw1 == 0L) calcDigitCount64(dw0) else calcDigitCount128(dw1, dw0)
    else
        return if (dw3 == 0L) calcDigitCount192(dw2, dw1, dw0) else calcDigitCount256(dw3, dw2, dw1, dw0)
}

